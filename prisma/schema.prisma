generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  nombre    String
  avatar    String?
  nit       String
  createdAt DateTime @default(now())

  compras  Compra[]
  facturas Factura[]

  // 🔥 AGREGA ESTO
  clientes Cliente[]

  logo String?
}

model Compra {
  id          String @id @default(cuid())
  descripcion String
  categoria   String
  total       Float
  base        Float
  iva         Float
  mes         Int
  anio        Int

  createdAt DateTime @default(now())

  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  // 🔥 NUEVO
  clienteId String?
  cliente   Cliente? @relation(fields: [clienteId], references: [id])

  uuid        String
  uuidFactura String
  deducible   Boolean @default(true)

  @@unique([uuid, usuarioId])
  @@index([uuidFactura])
  @@index([clienteId])
  @@index([clienteId, mes, anio])
}

model Resumen {
  id     String @id @default(cuid())
  userId String
  mes    Int
  anio   Int

  ventas      Float @default(0)
  debito      Float
  credito     Float
  iva         Float
  retenciones Float @default(0)

  bloqueado Boolean  @default(true)
  createdAt DateTime @default(now())

  // 🔥 RELACIÓN CORRECTA
  clienteId String?
  cliente   Cliente? @relation(fields: [clienteId], references: [id])

  @@unique([userId, mes, anio])
}

model MesCerrado {
  id        String @id @default(cuid())
  usuarioId String
  mes       Int
  anio      Int

  createdAt DateTime @default(now())

  @@unique([usuarioId, mes, anio])
}

model Factura {
  id String @id @default(cuid())

  descripcion String
  serie       String?
  numero      String?

  nit         String? // si lo usas general
  emisorNIT   String // 🔥 AGREGAR
  receptorNIT String // 🔥 AGREGAR

  total Float
  base  Float
  iva   Float

  categoria String?
  tipo      String?

  deducible Boolean @default(true) // 🔥 AGREGA ESTO

  mes  Int
  anio Int

  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  createdAt DateTime @default(now())
}

model Cliente {
  id     String @id @default(cuid())
  nombre String
  nit    String

  usuarioId String
  usuario   Usuario   @relation(fields: [usuarioId], references: [id])
  resumenes Resumen[]

  compras   Compra[]
  createdAt DateTime @default(now())

  @@unique([nit, usuarioId])
}
