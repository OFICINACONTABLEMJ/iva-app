generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  nombre    String
  avatar    String?
  createdAt DateTime @default(now())

  compras  Compra[]
  logo     String?
  facturas Factura[]
}

model Compra {
  id          String @id @default(cuid())
  descripcion String
  categoria   String
  total       Float
  base        Float
  iva         Float
  mes         Int
  anio        Int

  createdAt DateTime @default(now())

  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id])
  uuid      String?

  @@unique([uuid, usuarioId])
}

model Resumen {
  id     String @id @default(cuid())
  userId String
  mes    Int
  anio   Int

  ventas      Float @default(0)
  debito      Float
  credito     Float
  iva         Float
  retenciones Float @default(0)

  bloqueado Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([userId, mes, anio])
}

model MesCerrado {
  id        String @id @default(cuid())
  usuarioId String
  mes       Int
  anio      Int

  createdAt DateTime @default(now())

  @@unique([usuarioId, mes, anio])
}

model Factura {
  id          String   @id @default(cuid())
  descripcion String
  serie       String
  numero      String
  nit         String

  total       Float
  base        Float      // 🔥 AGREGAR
  iva         Float      // 🔥 AGREGAR
  categoria   String?    // 🔥 OPCIONAL
  tipo        String?    // 🔥 OPCIONAL

  mes         Int
  anio        Int

  usuarioId   String
  usuario     Usuario @relation(fields: [usuarioId], references: [id])

  createdAt   DateTime @default(now())
}